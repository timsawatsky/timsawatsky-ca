---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comments from '../../components/Comments.astro';

export async function getStaticPaths() {
	const reviews = await getCollection('reviews');
	return reviews.map((review) => ({
		params: { slug: review.id },
		props: review,
	}));
}

const review = Astro.props;
const { Content } = await render(review);
---

<BaseLayout title={review.data.title} description={review.data.description}>
	<div class="fade-in">
		<div class="flex flex-col md:flex-row gap-12 mb-12">
			<div class="w-full md:w-1/3">
				<img
					src={review.data.heroImage}
					alt={`Cover of ${review.data.title}`}
					class="w-full aspect-[2/3] object-cover rounded-xl shadow-lg border border-charcoal/5 sticky top-28"
				/>
			</div>
			<div class="w-full md:w-2/3">
				<header class="mb-8">
					<div class="flex items-center gap-4 text-sm font-sans font-medium text-charcoal/50 uppercase tracking-widest mb-4">
						<time datetime={review.data.pubDate.toISOString()}>
							{review.data.pubDate.toLocaleDateString('en-us', {
								year: 'numeric',
								month: 'long',
							})}
						</time>
						<span>•</span>
						<div class="flex gap-1 text-terracotta">
							{[...Array(5)].map((_, i) => (
								<span class={i < review.data.rating ? "opacity-100" : "opacity-30"}>★</span>
							))}
						</div>
					</div>
					<h1 class="text-4xl font-sans font-extrabold text-charcoal tracking-tight leading-tight mb-2">
						{review.data.title}
					</h1>
					<p class="text-xl text-charcoal/60 font-sans font-medium">by {review.data.author}</p>
				</header>

				<div class="prose prose-stone prose-lg max-w-none prose-headings:font-sans prose-headings:font-bold prose-a:text-terracotta hover:prose-a:underline">
					<Content />
				</div>

				{review.data.amazonId && (
					<div class="mt-12 p-8 bg-sage/5 rounded-2xl border border-sage/10 flex flex-col sm:flex-row items-center justify-between gap-6">
						<div>
							<h3 class="font-sans font-bold text-charcoal mb-1">Found this helpful?</h3>
							<p class="text-sm text-charcoal/60">Ordering through this link helps support this digital sanctuary.</p>
						</div>
						<a
							href={`https://www.amazon.com/dp/${review.data.amazonId}/?tag=timsawatsky-20`}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-terracotta text-white font-sans font-bold px-8 py-3 rounded-full hover:bg-terracotta/90 transition-all no-underline shadow-md hover:shadow-lg whitespace-nowrap"
						>
							Get it on Amazon
						</a>
					</div>
				)}
			</div>
		</div>
	</div>

	<Comments 
		pageId={review.id} 
		pageUrl={Astro.url.href} 
		pageTitle={review.data.title} 
	/>
</BaseLayout>
