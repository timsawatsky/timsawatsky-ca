---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Tim Sawatsky">
	<div class="fade-in">
		<div class="mt-16 p-12 bg-charcoal text-linen rounded-3xl text-center not-prose">
				<h2 class="text-3xl font-sans font-bold mb-4">Want to connect?</h2>
				
				<a 
					href="mailto:timsawatsky@gmail.com" 
					class="inline-block bg-terracotta text-white font-sans font-bold px-10 py-4 rounded-full hover:scale-105 transition-all no-underline"
				>
					Send me an email
				</a>
			</div>
				<p>Please note: This email is for general enquiries. If you are in crisis, please contact your local emergency services or a crisis hotline.</p>
			</div>
		</div>
	</div>
</BaseLayout>
