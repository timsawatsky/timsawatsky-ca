---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReflectionCard from '../components/ReflectionCard.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import BookCard from '../components/BookCard.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPost = posts[0];
const otherPosts = posts.slice(1, 3);

const latestReviews = (await getCollection('reviews')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 2);
---

<BaseLayout title="Home" description="Spiritual direction, counselling, and contemplative resources.">
	<div class="fade-in">
		<section class="mb-24">
			<div class="flex items-center gap-4 text-xs font-sans font-bold text-terracotta uppercase tracking-[0.2em] mb-6">
				<span class="w-8 h-px bg-terracotta"></span>
				<span>Latest Reflection</span>
			</div>
			
			{latestPost && (
				<article class="space-y-8">
					<h1 class="text-5xl md:text-7xl font-sans font-extrabold text-charcoal tracking-tight leading-[1.1] max-w-4xl">
						{latestPost.data.title}
					</h1>
					<p class="text-2xl leading-relaxed text-charcoal/70 max-w-2xl">
						{latestPost.data.description}
					</p>
					<div class="pt-4 flex items-center gap-6">
						<a 
							href={`/blog/${latestPost.id}/`} 
							class="bg-terracotta text-white font-sans font-bold px-10 py-4 rounded-full hover:scale-105 transition-all no-underline shadow-xl hover:shadow-2xl"
						>
							Read Full Reflection
						</a>
						<span class="text-sm font-sans font-medium text-charcoal/40 uppercase tracking-widest italic">
							{latestPost.data.pubDate.toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
						</span>
					</div>
				</article>
			)}
		</section>

		<section class="mb-24">
			<YouTubeEmbed />
		</section>

		<section class="grid md:grid-cols-2 gap-24 mb-24">
			<div class="space-y-12">
				<div class="flex items-center justify-between border-b border-charcoal/5 pb-6">
					<h2 class="text-2xl font-sans font-bold tracking-tight text-charcoal">Recent Reflections</h2>
					<a href="/blog" class="text-sm font-sans font-bold text-terracotta uppercase tracking-widest no-underline hover:underline">View All</a>
				</div>
				<div class="space-y-12">
					{otherPosts.map(post => (
						<div class="group relative space-y-3">
							<time class="text-xs font-sans font-medium text-charcoal/30 uppercase tracking-widest">{post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric' })}</time>
							<h3 class="text-xl font-sans font-extrabold text-charcoal group-hover:text-terracotta transition-colors">
								<a href={`/blog/${post.id}/`} class="no-underline after:absolute after:inset-0">{post.data.title}</a>
							</h3>
							<p class="text-charcoal/60 line-clamp-2 text-sm leading-relaxed">{post.data.description}</p>
						</div>
					))}
					{otherPosts.length === 0 && <p class="text-charcoal/40 italic">More reflections coming soon.</p>}
				</div>
			</div>

			<div class="space-y-12">
				<div class="flex items-center justify-between border-b border-charcoal/5 pb-6">
					<h2 class="text-2xl font-sans font-bold tracking-tight text-charcoal">Recommended Reading</h2>
					<a href="/reviews" class="text-sm font-sans font-bold text-terracotta uppercase tracking-widest no-underline hover:underline">View Grid</a>
				</div>
				<div class="grid gap-8">
					{latestReviews.map(review => (
						<div class="flex gap-6 items-center group relative">
							<div class="w-20 h-28 flex-shrink-0 overflow-hidden rounded-lg shadow-md group-hover:shadow-lg transition-shadow">
								<img src={review.data.heroImage} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
							</div>
							<div class="space-y-1">
								<div class="flex gap-1 text-[8px] text-terracotta">
									{[...Array(5)].map((_, i) => (
										<span class={i < review.data.rating ? "opacity-100" : "opacity-30"}>★</span>
									))}
								</div>
								<h3 class="text-lg font-sans font-extrabold text-charcoal group-hover:text-terracotta transition-colors">
									<a href={`/reviews/${review.id}/`} class="no-underline after:absolute after:inset-0">{review.data.title}</a>
								</h3>
								<p class="text-xs font-sans font-medium text-charcoal/40 uppercase tracking-widest">by {review.data.author}</p>
							</div>
						</div>
					))}
					{latestReviews.length === 0 && <p class="text-charcoal/40 italic">Coming soon.</p>}
				</div>
			</div>
		</section>
	</div>
</BaseLayout>
