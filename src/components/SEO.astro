---
// src/components/SEO.astro
interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article' | 'review';
	articleDate?: string;
	author?: string;
}

const { title, description, image, type, articleDate, author = "Tim Sawatsky" } = Astro.props;

const siteUrl = Astro.site?.toString() || "https://timsawatsky.ca/";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageUrl = image ? new URL(image, siteUrl) : new URL("/Tim-Alfie2.jpg", siteUrl);

// Base Person Schema
const personSchema = {
	"@type": "Person",
	"@id": `${siteUrl}#person`,
	"name": "Tim Sawatsky",
	"url": siteUrl,
	"jobTitle": "Spiritual Director & Counsellor",
	"description": "Providing reflections and resources for spiritual direction and counselling."
};

// Base WebSite Schema
const websiteSchema = {
	"@type": "WebSite",
	"@id": `${siteUrl}#website`,
	"url": siteUrl,
	"name": "Tim Sawatsky | Digital Sanctuary",
	"description": "Reflections and resources for spiritual direction and counselling.",
	"publisher": { "@id": `${siteUrl}#person` }
};

let pageSchema: any = null;

if (type === 'article') {
	pageSchema = {
		"@type": "BlogPosting",
		"@id": `${canonicalURL}#article`,
		"url": canonicalURL,
		"headline": title,
		"description": description,
		"image": imageUrl,
		"datePublished": articleDate,
		"author": { "@id": `${siteUrl}#person` },
		"publisher": { "@id": `${siteUrl}#person` },
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": canonicalURL
		}
	};
} else if (type === 'review') {
	pageSchema = {
		"@type": "Review",
		"@id": `${canonicalURL}#review`,
		"url": canonicalURL,
		"headline": title,
		"description": description,
		"image": imageUrl,
		"datePublished": articleDate,
		"author": { "@id": `${siteUrl}#person` },
		"reviewRating": {
			"@type": "Rating",
			"ratingValue": "5",
			"bestRating": "5"
		},
		"itemReviewed": {
			"@type": "Book",
			"name": title,
			"author": {
				"@type": "Person",
				"name": author
			}
		}
	};
}

const breadcrumbSchema = {
	"@type": "BreadcrumbList",
	"@id": `${canonicalURL}#breadcrumb`,
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": siteUrl
		},
		Astro.url.pathname !== '/' ? {
			"@type": "ListItem",
			"position": 2,
			"name": title,
			"item": canonicalURL
		} : null
	].filter(Boolean)
};

const schemas = [personSchema, websiteSchema, pageSchema, breadcrumbSchema].filter(Boolean);
---

{schemas.map(schema => (
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
